NODE_ENV=development
PORT=5000
API_PREFIX=/api

DATABASE_URL=postgres://postgres:postgres@localhost:5432/kaizen

CORS_ORIGIN=http://localhost:3000

LOG_LEVEL=info

COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Number of reverse-proxy hops to trust for X-Forwarded-For (0 = none, use
# the socket IP). Set to 1 behind a single load balancer/ingress.
TRUST_PROXY=0

# JWT Config
JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=kaizen-backend
JWT_AUDIENCE=kaizen-app

# Rate limiting (all optional, defaults shown)
RATE_LIMIT_AUTH_REGISTER_WINDOW_MS=900000
RATE_LIMIT_AUTH_REGISTER_MAX=5
RATE_LIMIT_AUTH_LOGIN_WINDOW_MS=60000
RATE_LIMIT_AUTH_LOGIN_MAX=10
RATE_LIMIT_AUTH_REFRESH_WINDOW_MS=60000
RATE_LIMIT_AUTH_REFRESH_MAX=30
RATE_LIMIT_AUTH_ME_WINDOW_MS=60000
RATE_LIMIT_AUTH_ME_MAX=100
